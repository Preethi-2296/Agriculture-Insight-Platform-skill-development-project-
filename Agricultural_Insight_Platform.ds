 application "Agricultural Insight Platform"
 {
 	date format = "dd-MMM-yyyy"
 	time zone = "America/Los_Angeles"
 	time format = "24-hr"
 	forms
	{
		form ai_query
		{
			displayname = "AI Query"
			success message = "Ai Query Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			query_text
			(
    			type = textarea
				displayname = "Query Text"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			response_text
			(
    			type = textarea
				displayname = "Response Text"
				height = 100px
	 			row = 1
	 			column = 1   
				width = medium
			)
			query_timestamp
			(
    			type = datetime
				displayname = "Query Timestamp"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			user_query_id
			(
    			type = autonumber
				displayname = "User Query Id"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
			related_crop
			(
				type = list	
				displayname = "Related Crop"
				values  = crop_recommendation.ID
    			displayformat = [recommended_crop]
				allow new entries
				[
					displayname = "Add New"
				]
				sortorder = ascending
				height = 13px
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
		}
		form crop_recommendation
		{
			displayname = "Crop Recommendation"
			success message = "Crop Recommendation Added Successfully"
			Section
			(
				type = section
	 			row = 1
	 			column = 0   
				width = medium
			)
			soil_type
			(
				type = picklist
				displayname = "Soil Type"
				values = {"Clay","Chalky","Sandy","Loam","Peat"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			climate_zone
			(
				type = picklist
				displayname = "Climate Zone"
				values = {"Arid","Temperate","Subtropical","Semi-arid","Tropical"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			historical_yield
			(
				type = number
				displayname = "Historical Yield"
				maxchar = 19
	 			row = 1
	 			column = 1   
				width = medium
			)
			recommended_crop
			(
    			type = text
				displayname = "Recommended Crop"
	 			row = 1
	 			column = 1   
				width = medium
			)
			season
			(
				type = picklist
				displayname = "Season"
				values = {"Winter","Autumn","Summer","Spring"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			soil_ph
			(
				type = decimal
				displayname = "Soil PH"
				maxchar = 16
	 			row = 1
	 			column = 1   
				width = medium
			)
			moisture_level
			(
				type = picklist
				displayname = "Moisture Level"
				values = {"High","Moderate","Dry"}
				others option = true
	 			row = 1
	 			column = 1   
				width = medium
			)
			suggestion_date
			(
    			type = date
				displayname = "Suggestion Date"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			last_updated
			(
    			type = datetime
				displayname = "Last Updated"
				timedisplayoptions = "hh:mm:ss"
				alloweddays = 0,1,2,3,4,5,6
	 			row = 1
	 			column = 1   
				width = medium
			)
			recommendation_id
			(
    			type = autonumber
				displayname = "Recommendation Id"
				start index = 1
	 			row = 1
	 			column = 1   
				width = medium
			)
	
			actions
			{
				on add
				{
					submit
					(
   						type = submit
   						displayname = "Submit"
					)
					reset
					(
   						type = reset
   						displayname = "Reset"
					)
				}
				on edit
				{
					update
					(
   						type = submit
   						displayname = "Update"
					)
					cancel
					(
   						type = cancel
   						displayname = "Cancel"
					)
				}
			}
			blueprint components
			{
				stages = {"Crop Recommendation Requested","Data Validation In Progress","Recommendation Generation Failed","Recommendation Generation In Progress","Recommendation Generated","Recommendation Reviewed","Recommendation Rejected","Recommendation Approved","Recommendation Published","Recommendation Archived","Recommendation Updated"}
			}
		}
