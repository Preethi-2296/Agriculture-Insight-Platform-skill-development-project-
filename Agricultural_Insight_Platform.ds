	reports
	{
		list farm_data_Report
		{
			displayName = "All Farm Data"
			show all rows from farm_data    
			(
				farm_name as "Farm Name"
				location as "Location"
				planting_date as "Planting Date"
				irrigation_schedule as "Irrigation Schedule"
				harvest_output as "Harvest Output"
				crop_type as "Crop Type"
				soil_test_id as "Soil Test Id"
				farm_manager as "Farm Manager"
			)
		}
		list ai_query_Report
		{
			displayName = "All Ai Queries"
			show all rows from ai_query    
			(
				query_text as "Query Text"
				response_text as "Response Text"
				query_timestamp as "Query Timestamp"
				user_query_id as "User Query Id"
				related_crop as "Related Crop"
			)
		}
		list soil_test_Report
		{
			displayName = "All Soil Tests"
			show all rows from soil_test    
			(
				soil_test_id as "Soil Test Id"
				farm_name as "Farm Name"
				test_date as "Test Date"
				ph_level as "PH Level"
				nitrogen as "Nitrogen"
				phosphorus as "Phosphorus"
				potassium as "Potassium"
				organic_matter as "Organic Matter"
				(
					display = total,average,min,max	
				)
				test_result as "Test Result"
				soil_health_trend as "Soil Health Trend"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (test_result == "Good")
				fields = [test_result]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (test_result == "Poor")
				fields = [test_result]
				format = "color:#000000;background-color:#1bbc9b;"
				}
			)
		}
		kanban soil_test_by_test_result
		{
			displayName = "Test Results"
			show all rows from soil_test    
			(
				soil_test_id as "Soil Test Id"
				farm_name as "Farm Name"
				test_date as "Test Date"
				ph_level as "PH Level"
				nitrogen as "Nitrogen"
				phosphorus as "Phosphorus"
				potassium as "Potassium"
				organic_matter as "Organic Matter"
				(
					display = total,average,min,max	
				)
				test_result as "Test Result"
				soil_health_trend as "Soil Health Trend"
			)
			options
			(
	 			display field = test_result
	 		)
		}
		list crop_recommendation_Report
		{
			displayName = "All Crop Recommendations"
			show all rows from crop_recommendation    
			(
				soil_type as "Soil Type"
				climate_zone as "Climate Zone"
				historical_yield as "Historical Yield"
				recommended_crop as "Recommended Crop"
				season as "Season"
				soil_ph as "Soil PH"
				moisture_level as "Moisture Level"
				suggestion_date as "Suggestion Date"
				last_updated as "Last Updated"
				recommendation_id as "Recommendation Id"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (soil_type == "Loam")
				fields = [soil_type]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (soil_type == "Peat")
				fields = [soil_type]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (soil_type == "Sandy")
				fields = [soil_type]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban crop_recommendation_by_soil_type
		{
			displayName = "Soil Types"
			show all rows from crop_recommendation    
			(
				soil_type as "Soil Type"
				climate_zone as "Climate Zone"
				historical_yield as "Historical Yield"
				recommended_crop as "Recommended Crop"
				season as "Season"
				soil_ph as "Soil PH"
				moisture_level as "Moisture Level"
				suggestion_date as "Suggestion Date"
				last_updated as "Last Updated"
				recommendation_id as "Recommendation Id"
			)
			options
			(
	 			display field = soil_type
	 		)
		}
		list farm_layout_Report
		{
			displayName = "All Farm Layouts"
			show all rows from farm_layout    
			(
				layout_name as "Layout Name"
				farm_name as "Farm Name"
				ai_generated_image as "AI Generated Image"
				crop_rotation_plan as "Crop Rotation Plan"
				planning_date as "Planning Date"
				layout_version as "Layout Version"
				visual_description as "Visual Description"
				area_size as "Area Size"
				designer as "Designer"
			)
		}
		list weather_forecast_Report
		{
			displayName = "All Weather Forecasts"
			show all rows from weather_forecast    
			(
				location as "Location"
				forecast_date as "Forecast Date"
				temperature as "Temperature"
				precipitation as "Precipitation"
				wind_speed as "Wind Speed"
				humidity as "Humidity"
				(
					display = total,average,min,max	
				)
				weather_condition as "Weather Condition"
				alert_level as "Alert Level"
				forecast_id as "Forecast Id"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (weather_condition == "Partly Cloudy")
				fields = [weather_condition]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (weather_condition == "Rainy")
				fields = [weather_condition]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (weather_condition == "Stormy")
				fields = [weather_condition]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban weather_forecast_by_weather_condition
		{
			displayName = "Weather Conditions"
			show all rows from weather_forecast    
			(
				location as "Location"
				forecast_date as "Forecast Date"
				temperature as "Temperature"
				precipitation as "Precipitation"
				wind_speed as "Wind Speed"
				humidity as "Humidity"
				(
					display = total,average,min,max	
				)
				weather_condition as "Weather Condition"
				alert_level as "Alert Level"
				forecast_id as "Forecast Id"
			)
			options
			(
	 			display field = weather_condition
	 		)
		}
		list soil_health_analysis_Report
		{
			displayName = "All Soil Health Analyses"
			show all rows from soil_health_analysis    
			(
				soil_test_id as "Soil Test Id"
				trend_period as "Trend Period"
				health_score as "Health Score"
				recommendation as "Recommendation"
				analysis_date as "Analysis Date"
				trend_direction as "Trend Direction"
				action_plan as "Action Plan"
				analyst as "Analyst"
			)
			conditional formatting
			(
				"New Formatting1"
				{
				condition = (trend_period == "1 Year")
				fields = [trend_period]
				format = "color:#ffffff;background-color:#765f89;"
				}
				"New Formatting2"
				{
				condition = (trend_period == "3 Months")
				fields = [trend_period]
				format = "color:#000000;background-color:#1bbc9b;"
				}
				"New Formatting3"
				{
				condition = (trend_period == "6 Months")
				fields = [trend_period]
				format = "color:#ffffff;background-color:#e84c3d;"
				}
			)
		}
		kanban soil_health_analysis_by_trend_period
		{
			displayName = "Trend Periods"
			show all rows from soil_health_analysis    
			(
				soil_test_id as "Soil Test Id"
				trend_period as "Trend Period"
				health_score as "Health Score"
				recommendation as "Recommendation"
				analysis_date as "Analysis Date"
				trend_direction as "Trend Direction"
				action_plan as "Action Plan"
				analyst as "Analyst"
			)
			options
			(
	 			display field = trend_period
	 		)
		}
	}
